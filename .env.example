# ============================================================
# Edge Face Capture & Recognition System - Configuration
# Copy this file to .env and adjust values for your deployment.
# Every value can also be overridden as a container env var.
# ============================================================

# ---- Camera ------------------------------------------------
RTSP_URL=rtsp://admin:Admin%40123@192.168.6.61:554/Streaming/Channels/601
# tcp (default) is required inside Docker; udp only works with host networking.
RTSP_TRANSPORT=tcp
CAMERA_NAME=camera-1
CAMERA_RECONNECT_MIN_DELAY=1.0
CAMERA_RECONNECT_MAX_DELAY=30.0

# ---- Detection ---------------------------------------------
# SCRFD detector (part of the InsightFace model pack below).
# Keep moderate: side/partial faces score 0.3-0.45 and must clear this bar
# to be tracked at all — too high means only frontal faces get captured.
DETECTION_CONFIDENCE=0.40
# Detector input size (square). 640 = accurate, 480/320 = faster on CPU.
DETECTION_SIZE=640
# Run detection on every Nth frame (1 = every frame). Raise to 2-3 on CPU.
DETECT_EVERY_N_FRAMES=2
# Faces smaller than this (pixels, min side) are ignored.
MIN_FACE_SIZE=40

# ---- Tracking (ByteTrack-style) ------------------------------
TRACK_MATCH_IOU=0.30
TRACK_MIN_HITS=2
TRACK_MAX_LOST_FRAMES=30
TRACK_LOW_SCORE_THRESHOLD=0.30

# ---- Capture / saving ---------------------------------------
# Optional capture zone: faces are saved only when their center is inside
# this polygon. Normalized coordinates (0..1, origin top-left), at least
# 3 "x,y" points separated by ";". Empty = capture anywhere in the frame.
# Example (center rectangle): 0.25,0.25;0.75,0.25;0.75,0.90;0.25,0.90
# NOTE: a zone drawn in the dashboard (Live View → Draw capture zone) is
# stored in the data volume and overrides this value.
CAPTURE_ZONE=
# Also store the full camera frame for every captured face (frames/ dir).
SAVE_FULL_FRAME=true
# Minimum seconds between saved images of the same track.
SAVE_INTERVAL_SECONDS=10
# Padding added around the detected face box before cropping (fraction).
FACE_CROP_PADDING=0.20
# Saved face image size (square): 160 or 224 recommended.
FACE_CROP_SIZE=224
JPEG_QUALITY=90

# ---- Quality gate -------------------------------------------
# Composite quality score in [0,1]; faces below this are rejected.
QUALITY_MIN_SCORE=0.45
# Variance-of-Laplacian below this counts as blurry.
QUALITY_BLUR_THRESHOLD=45.0
QUALITY_BRIGHTNESS_MIN=40
QUALITY_BRIGHTNESS_MAX=215

# ---- Inference hardware ---------------------------------------
# cpu (default) or npu. NPU needs an onnxruntime build with the board's NPU
# execution provider (VSINPU on Radxa Cubie A7Z / Allwinner A733, RKNPU on
# Rockchip); without it the app logs a warning and runs on CPU. Can also be
# changed from the dashboard Settings page (that choice overrides this).
INFERENCE_BACKEND=cpu

# ---- Embeddings / vector search ------------------------------
# InsightFace model pack (SCRFD detector + ArcFace 512-d recognizer).
EMBEDDING_MODEL=buffalo_l
# Cosine similarity above this marks a capture as a possible duplicate.
DUPLICATE_THRESHOLD=0.92
# How often (seconds) the FAISS index is flushed to disk.
FAISS_SAVE_INTERVAL=60

# ---- Storage -------------------------------------------------
# Root of all persistent data (inside the container; mounted as a volume).
STORAGE_ROOT=/app/storage

# ---- Queues (bounded; protect memory) -------------------------
FRAME_QUEUE_SIZE=4
EMBED_QUEUE_SIZE=32
PERSIST_QUEUE_SIZE=64

# ---- Live view -----------------------------------------------
LIVE_STREAM_FPS=8
LIVE_STREAM_WIDTH=960

# ---- API / server ---------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Interval (seconds) between statistics broadcasts over WebSocket.
STATS_INTERVAL=2.0

# ---- Logging ---------------------------------------------------
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=14

# ---- Frontend (host port mapping used by docker-compose) -------
DASHBOARD_PORT=8080
BACKEND_PORT=8000
